# Copia in .env per esecuzione locale. Su GitHub Actions usa Repository Secrets.

# Google Calendar API (service account JSON intero, su una sola riga, oppure path al file)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary

# URL pubblica della dashboard (per il link nell'evento Calendar)
DASHBOARD_URL=https://<tuo-username>.github.io/<nome-repo>/

# User-Agent per scraping (impostane uno realistico)
SCRAPER_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 13_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Modalità: dry_run=true salta Calendar API e usa fixtures
DRY_RUN=false
